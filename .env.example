# Copy this file to .env and fill in real values.
# Pull these from the Firebase / Google Cloud console.

# Firebase API keys, one per platform.
FIREBASE_WEB_API_KEY=
FIREBASE_ANDROID_API_KEY=
FIREBASE_IOS_API_KEY=

# YouTube Data API v3 key. Used by admin screens to ingest channels/videos.
# Restrict this key to the YouTube Data API v3 in GCP.
YOUTUBE_API_KEY=
